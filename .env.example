DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/bn_monitor
BINANCE_REST_URL=https://fapi.binance.com
BINANCE_WS_URL=wss://fstream.binance.com/stream
UNIVERSE_MODE=top_usdt
SYMBOLS=
ALERT_MODE=shadow
DISCORD_WEBHOOK_URL=
DISCORD_MIN_SEVERITY=WARNING
DISCORD_ALERT_TYPE_ALLOWLIST=
DATA_RETENTION_DAYS=30
PRICE_THRESHOLD_BPS=100
VOLUME_PERCENTILE_THRESHOLD=0.95
VOLUME_ROBUST_Z_THRESHOLD=3.0
ALERT_COOLDOWN_MINUTES=10

# 规则阈值覆盖（两层 JSON，留空或 {} 表示使用内置默认值）
# 格式：{"alert_type": {"key": "value"}}
# 默认值：
# flat_oi_buildup_15m:  return_limit=0.005, oi_buildup_threshold=0.03
# daily_flat_oi_buildup: return_limit=0.03, oi_buildup_threshold=0.10
# breakout_watch:       near_high_bps=80, range_compression_max=0.70, volume_z_min=2.5, taker_buy_min=0.60, market_return_min=0
# breakdown_watch:      low_distance_bps=80, range_compression_max=0.70, volume_z_min=2.5, taker_sell_min=0.60
# 示例：RULE_THRESHOLDS={"breakout_watch": {"volume_z_min": "2.2"}, "flat_oi_buildup_15m": {"oi_buildup_threshold": "0.02"}}
RULE_THRESHOLDS={}
