DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/bn_monitor
BINANCE_REST_URL=https://fapi.binance.com
BINANCE_WS_URL=wss://fstream.binance.com/stream
UNIVERSE_MODE=top_usdt
SYMBOLS=
ALERT_MODE=shadow
DISCORD_WEBHOOK_URL=
DISCORD_MIN_SEVERITY=WARNING
DISCORD_ALERT_TYPE_ALLOWLIST=
DATA_RETENTION_DAYS=30
PRICE_THRESHOLD_BPS=100
VOLUME_PERCENTILE_THRESHOLD=0.95
VOLUME_ROBUST_Z_THRESHOLD=3.0
ALERT_COOLDOWN_MINUTES=10

# 规则阈值覆盖（JSON object，留空或 {} 表示使用内置默认值）
# 可用 key：DAILY_FLAT_RETURN_LIMIT, DAILY_OI_BUILDUP_THRESHOLD,
#           FLAT_15M_RETURN_LIMIT, OI_BUILDUP_15M_THRESHOLD,
#           BREAKOUT_NEAR_HIGH_BPS, BREAKOUT_RANGE_COMPRESSION_MAX,
#           BREAKOUT_VOLUME_ROBUST_Z_MIN, BREAKOUT_TAKER_BUY_RATIO_MIN,
#           BREAKOUT_MARKET_RELATIVE_RETURN_MIN,
#           BREAKDOWN_LOW_DISTANCE_BPS, BREAKDOWN_RANGE_COMPRESSION_MAX,
#           BREAKDOWN_VOLUME_ROBUST_Z_MIN, BREAKDOWN_TAKER_SELL_RATIO_MIN
# 示例：RULE_THRESHOLDS={"FLAT_15M_RETURN_LIMIT": "0.008", "OI_BUILDUP_15M_THRESHOLD": "0.05"}
RULE_THRESHOLDS={}
