DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/bn_monitor
BINANCE_REST_URL=https://fapi.binance.com
BINANCE_WS_URL=wss://fstream.binance.com/stream
UNIVERSE_MODE=top_usdt
SYMBOLS=
ALERT_MODE=shadow
DISCORD_WEBHOOK_URL=
DISCORD_MIN_SEVERITY=WARNING
DISCORD_ALERT_TYPE_ALLOWLIST=
DATA_RETENTION_DAYS=30
PRICE_THRESHOLD_BPS=100
VOLUME_PERCENTILE_THRESHOLD=0.95
VOLUME_ROBUST_Z_THRESHOLD=3.0
ALERT_COOLDOWN_MINUTES=10

# 规则阈值覆盖（两层 JSON，留空或 {} 表示使用内置默认值）
# 格式：{"alert_type": {"key": "value"}}
# flat_oi_buildup_15m:  return_limit, oi_buildup_threshold
# daily_flat_oi_buildup: return_limit, oi_buildup_threshold
# breakout_watch:       near_high_bps, range_compression_max, volume_z_min, taker_buy_min, market_return_min
# breakdown_watch:      low_distance_bps, range_compression_max, volume_z_min, taker_sell_min
# 示例：RULE_THRESHOLDS={"breakout_watch": {"near_high_bps": "40"}, "flat_oi_buildup_15m": {"return_limit": "0.008"}}
RULE_THRESHOLDS={}
